---
import BaseHead from '../components/BaseHead.astro';
import AsciiCursorTrail from '../components/AsciiCursorTrail.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} — RSS Feed`} description="RSS feed for David Bloom's essays." />
	</head>
	<body>
		<AsciiCursorTrail />
		<div class="feed">
			<div class="feed-shell">
				<div class="feed-header">
					<h1 class="feed-title">{SITE_TITLE}</h1>
					<nav class="feed-nav">
						<a href="/">Home</a>
						<button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle dark mode">●</button>
					</nav>
				</div>
				<p class="feed-about">
					This is an RSS feed. <button class="feed-copy" id="feed-copy" type="button">Copy feed URL</button> and paste it into your feed reader to subscribe.
					Visit <a href="https://aboutfeeds.com">About Feeds</a> to learn more.
				</p>
				<span class="feed-label">Essays</span>
				<ul class="feed-list">
					{posts.map((post) => (
						<li>
							<FormattedDate date={post.data.pubDate} />
							<a class="feed-post-title" href={`/essays/${post.id}/`}>{post.data.title}</a>
							{post.data.description && (
								<p class="feed-post-desc">{post.data.description}</p>
							)}
						</li>
					))}
				</ul>
			</div>
		</div>
		<script is:inline>
		(function() {
			var btn = document.getElementById('theme-toggle');
			if (btn) {
				btn.addEventListener('click', function() {
					var current = document.documentElement.dataset.theme;
					var next = current === 'dark' ? 'light' : 'dark';
					document.documentElement.dataset.theme = next;
					localStorage.setItem('theme', next);
				});
			}
			var copyBtn = document.getElementById('feed-copy');
			if (copyBtn) {
				copyBtn.addEventListener('click', function() {
					var url = window.location.origin + '/rss.xml';
					navigator.clipboard.writeText(url).then(function() {
						copyBtn.textContent = 'Copied!';
						setTimeout(function() { copyBtn.textContent = 'Copy feed URL'; }, 2000);
					});
				});
			}
		})();
		</script>
	</body>
</html>

<style>
	.feed {
		padding: 3rem 2rem 2.5rem;
	}
	.feed-shell {
		max-width: 560px;
		margin: 0 auto;
	}
	.feed-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		margin-bottom: 1.5rem;
	}
	.feed-title {
		font-family: var(--font-ui);
		font-size: 1.55rem;
		font-weight: 600;
		line-height: 1;
		margin: 0;
	}
	.feed-nav {
		display: flex;
		gap: 1.25em;
		align-items: baseline;
		font-family: var(--font-ui);
		font-size: var(--font-size-ui);
	}
	.feed-nav a {
		color: var(--text-muted);
		text-decoration: none;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		font-weight: 500;
	}
	.feed-nav a:hover {
		color: var(--accent);
	}
	.theme-toggle {
		background: none;
		border: none;
		cursor: pointer;
		font-size: 0.6rem;
		color: var(--text-muted);
		padding: 0;
		line-height: 1;
		transition: color 0.15s ease-in-out;
	}
	.theme-toggle:hover {
		color: var(--accent);
	}
	.feed-about {
		font-family: var(--font-ui);
		font-size: 0.9rem;
		color: var(--text-muted);
		margin-bottom: 2rem;
		line-height: 1.55;
	}
	.feed-copy {
		font-family: var(--font-ui);
		font-size: inherit;
		font-weight: 500;
		background: none;
		border: none;
		border-bottom: 1px solid var(--border);
		padding: 0;
		cursor: pointer;
		color: var(--accent);
		transition: color 0.15s ease-in-out;
	}
	.feed-copy:hover {
		color: var(--accent-hover);
	}
	.feed-about a {
		color: var(--accent);
		text-decoration: none;
	}
	.feed-about a:hover {
		text-decoration: underline;
	}
	.feed-label {
		font-family: var(--font-ui);
		font-size: 0.9rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-muted);
		display: block;
		margin-bottom: 0.6em;
	}
	.feed-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.feed-list li {
		margin-bottom: 0.9em;
	}
	.feed-post-title {
		display: block;
		font-family: var(--font-body);
		font-size: 1.25rem;
		font-weight: 400;
		color: var(--text);
		text-decoration: none;
		line-height: 1.3;
	}
	.feed-post-title:hover {
		color: var(--accent);
		text-decoration: none;
	}
	.feed-post-desc {
		font-family: var(--font-body);
		font-size: 0.9rem;
		font-weight: 300;
		color: var(--text-muted);
		line-height: 1.45;
		margin: 0.2em 0 0;
	}
	.feed :global(time) {
		font-size: 0.8rem;
	}
</style>
